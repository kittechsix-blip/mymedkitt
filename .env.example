# MedKitt Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Supabase service role key — for deploy scripts ONLY. Never use client-side.
SUPABASE_SERVICE_ROLE_KEY=

# EBMedicine scraper credentials (used by scraper/ only)
EBMEDICINE_EMAIL=
EBMEDICINE_PASSWORD=

# UpToDate scraper credentials (used by scraper/ only)
UPTODATE_USERNAME=
UPTODATE_PASSWORD=
