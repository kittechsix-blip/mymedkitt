{
  "version": "1.0.0",
  "experimentDuration": "5m",
  "maxExperimentsPerNight": 100,
  "metricsEndpoint": "http://localhost:5173",

  "ux": {
    "enabled": true,
    "variants": [
      {
        "id": "primary-color",
        "property": "--color-primary",
        "values": ["#2563eb", "#3b82f6", "#1d4ed8", "#0ea5e9", "#0284c7"]
      },
      {
        "id": "font-size-base",
        "property": "--font-size-base",
        "values": ["14px", "15px", "16px", "17px"]
      },
      {
        "id": "card-padding",
        "property": "--card-padding",
        "values": ["12px", "16px", "20px", "24px"]
      },
      {
        "id": "button-radius",
        "property": "--button-radius",
        "values": ["4px", "6px", "8px", "12px", "9999px"]
      },
      {
        "id": "header-height",
        "property": "--header-height",
        "values": ["48px", "56px", "64px"]
      }
    ],
    "metrics": ["lighthouse-performance", "lighthouse-accessibility", "cls", "lcp"]
  },

  "content": {
    "enabled": true,
    "targetNodes": [
      "afib-rvr",
      "sepsis",
      "chest-pain",
      "syncope"
    ],
    "optimizations": [
      {
        "id": "abbreviation-expansion",
        "description": "Test abbreviated vs expanded medical terms",
        "metric": "readability-score"
      },
      {
        "id": "step-reordering",
        "description": "Test different orderings of action steps",
        "metric": "completion-time"
      },
      {
        "id": "phrasing-clarity",
        "description": "LLM-generated alternate phrasings",
        "metric": "flesch-kincaid"
      }
    ],
    "llmProvider": "anthropic",
    "llmModel": "claude-3-5-haiku-20241022"
  },

  "search": {
    "enabled": true,
    "testQueries": [
      { "query": "afib", "expectedTop": "afib-rvr" },
      { "query": "chest pain", "expectedTop": "chest-pain-acs" },
      { "query": "sepsis antibiotics", "expectedTop": "sepsis" },
      { "query": "broken arm", "expectedTop": "fracture-management" },
      { "query": "stroke", "expectedTop": "stroke-tpa" },
      { "query": "DKA", "expectedTop": "dka" },
      { "query": "intubation", "expectedTop": "airway-rsi" },
      { "query": "PE", "expectedTop": "pe-treatment" },
      { "query": "hypertensive emergency", "expectedTop": "htn-emergency" },
      { "query": "seizure", "expectedTop": "status-epilepticus" }
    ],
    "weights": {
      "baseline": { "title": 10, "tags": 5, "body": 1 },
      "variants": [
        { "title": 15, "tags": 5, "body": 1 },
        { "title": 10, "tags": 8, "body": 1 },
        { "title": 10, "tags": 5, "body": 2 },
        { "title": 12, "tags": 6, "body": 2 },
        { "title": 8, "tags": 10, "body": 1 }
      ]
    },
    "fuzzyThresholds": [0.3, 0.4, 0.5, 0.6]
  },

  "output": {
    "resultsDir": "./results",
    "winnersDir": "./winners",
    "logLevel": "info"
  },

  "uxParadigm": {
    "enabled": true,
    "description": "Benchmark clinical scenarios to measure time-to-answer",
    "scenarios": [
      "afib-stable-dose",
      "sepsis-antibiotics",
      "pe-tpa-dose",
      "dka-insulin",
      "rsi-drugs"
    ],
    "targetMetrics": {
      "maxTimeMs": 3000,
      "maxTaps": 3,
      "minScore": 80
    }
  }
}
